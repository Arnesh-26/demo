# Clinical Consultation Copilot Environment Configurations

# JWT Configuration
CLINICAL_COPILOT_JWT_SECRET_KEY=production-jwt-secret-key-change-me
CLINICAL_COPILOT_JWT_ALGORITHM=HS256

# Queue Configurations
CLINICAL_COPILOT_QUEUE_MAX_SIZE=100
CLINICAL_COPILOT_QUEUE_OVERFLOW_STRATEGY=drop_oldest

# ElevenLabs Speech-to-Text API Key
CLINICAL_COPILOT_ELEVENLABS_API_KEY=
# STT Mode: development (offline mocks) or production (live ElevenLabs WebSocket)
CLINICAL_COPILOT_STT_PROVIDER_MODE=development

# Hugging Face Access Token (required for Pyannote gated repositories)
CLINICAL_COPILOT_HUGGINGFACE_TOKEN=
# Diarization Mode: development (offline mocks) or production (live Pyannote model)
CLINICAL_COPILOT_DIARIZATION_MODE=development
# Rolling audio buffer retained per session in seconds (default: 7)
CLINICAL_COPILOT_DIARIZATION_BUFFER_SECONDS=7
# Audio window fed into Pyannote per inference cycle in seconds (default: 5)
CLINICAL_COPILOT_DIARIZATION_WINDOW_SECONDS=5
# How often the inference cycle fires in seconds (default: 2)
CLINICAL_COPILOT_DIARIZATION_INTERVAL_SECONDS=2
